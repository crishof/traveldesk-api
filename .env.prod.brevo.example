# ============================
# Perfil
# ============================
SPRING_PROFILES_ACTIVE=prod

# ============================
# Seguridad
# ============================
BASE64_SECRET_KEY=replace_with_base64_256_bit_key

# ============================
# Datasource (Railway / Postgres)
# ============================
SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=replace_with_password

# ============================
# Frontend URLs (prod)
# ============================
CORS_ALLOWED_ORIGINS=https://traveldesk-pi.vercel.app
RESET_PASSWORD_BASE_URL=https://traveldesk-pi.vercel.app/reset-password
ACCEPT_INVITE_BASE_URL=https://traveldesk-pi.vercel.app/accept-invite

# ============================
# Brevo API (recomendado en plataformas que bloquean SMTP)
# ============================
MAIL_ENABLED=true
MAIL_PROVIDER=brevo-api
BREVO_API_URL=https://api.brevo.com/v3
BREVO_API_KEY=replace_with_brevo_api_key
BREVO_API_TIMEOUT_SECONDS=15
MAIL_FROM=no-reply@traveldesk.app

# ============================
# Brevo SMTP (fallback opcional)
# ============================
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=replace_with_brevo_smtp_login
MAIL_PASSWORD=replace_with_brevo_smtp_key
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
MAIL_SMTP_SSL_ENABLE=false
MAIL_SMTP_CONNECTION_TIMEOUT=30000
MAIL_SMTP_TIMEOUT=30000
MAIL_SMTP_WRITE_TIMEOUT=30000
EMAIL_VERIFICATION_CODE_TTL_MINUTES=10

# ============================
# External APIs
# ============================
FREE_CURRENCY_APIKEY=replace_with_api_key

